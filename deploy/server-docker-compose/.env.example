# Copy to .env, then replace every CHANGE_ME value before running deploy.sh.
# Keep .env mode 0600 and never commit it.

COMPOSE_PROJECT_NAME=distr-prod
AWS_REGION=ap-southeast-1
ECR_REPOSITORY=distr-community
DISTR_IMAGE=CHANGE_ME_AWS_ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/distr-community
DISTR_IMAGE_TAG=236a463d
DISTR_IMAGE_REF=CHANGE_ME_AWS_ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/distr-community@sha256:CHANGE_ME_IMAGE_DIGEST
DISTR_HTTP_PORT=8080
DISTR_REGISTRY_PORT=8585
NGINX_UI_NETWORK=services

# Database
POSTGRES_USER=distr
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_DEPLOY_SH_INIT
POSTGRES_DB=distr
DATABASE_URL=postgres://distr:CHANGE_ME_GENERATE_WITH_DEPLOY_SH_INIT@postgres:5432/distr?sslmode=disable
DATABASE_MAX_CONNS=20

# Public URLs behind your reverse proxy.
DISTR_HOST=https://distr.example.com
REGISTRY_HOST=registry.example.com

# Security
JWT_SECRET=CHANGE_ME_BASE64_32_BYTES
USER_EMAIL_VERIFICATION_REQUIRED=false
REGISTRATION=enabled
INVITE_TOKEN_VALID_DURATION=72h
AGENT_TOKEN_MAX_VALID_DURATION=24h

# Enable the completed community roadmap surfaces.
DISTR_EXPERIMENTAL_FEATURE_FLAGS=environments,lifecycles,channels,release_bundles,deployment_processes,scoped_variables_v2,deployment_plans,task_queue,agent_capabilities,agent_task_leases,step_events,deployment_timeline,retention_policies,observability_metrics,observability_tracing,observability_dashboards,observability_correlation,config_as_code

# Built-in OCI registry backed by local RustFS. This starter Compose stack always
# runs RustFS; for stronger production durability, adapt the Compose file to use
# external S3-compatible storage with backups/versioning.
REGISTRY_ENABLED=true
REGISTRY_S3_BUCKET=distr
REGISTRY_S3_CREATE_BUCKET=true
REGISTRY_S3_REGION=local
REGISTRY_S3_ENDPOINT=http://storage:9000
REGISTRY_S3_ACCESS_KEY_ID=local
REGISTRY_S3_SECRET_ACCESS_KEY=CHANGE_ME_GENERATE_WITH_DEPLOY_SH_INIT
REGISTRY_S3_USE_PATH_STYLE=true
REGISTRY_S3_ALLOW_REDIRECT=true
RUSTFS_ACCESS_KEY=local
RUSTFS_SECRET_KEY=CHANGE_ME_GENERATE_WITH_DEPLOY_SH_INIT

# Metrics are not published by docker-compose.yml. Expose them only on a private network.
METRICS_ENABLED=false
METRICS_ADDR=:3000
METRICS_BEARER_TOKEN=
OBSERVABILITY_GRAFANA_BASE_URL=

# Mail. Keep verification disabled until SMTP/SES is configured.
# MAILER_TYPE=smtp
# MAILER_FROM_ADDRESS=noreply@distr.example.com
# MAILER_SMTP_HOST=smtp.example.com
# MAILER_SMTP_PORT=587
# MAILER_SMTP_USERNAME=
# MAILER_SMTP_PASSWORD=
# MAILER_SMTP_IMPLICIT_TLS=false

# Cleanup jobs
STATUS_ENTRIES_MAX_AGE=1h
METRICS_ENTRIES_MAX_AGE=1h
LOG_RECORD_ENTRIES_MAX_COUNT=500
CLEANUP_DEPLOYMENT_REVISION_STATUS_CRON="0 * * * *"
CLEANUP_DEPLOYMENT_REVISION_STATUS_TIMEOUT=10m
CLEANUP_DEPLOYMENT_TARGET_METRICS_CRON="0 * * * *"
CLEANUP_DEPLOYMENT_TARGET_METRICS_TIMEOUT=10m
CLEANUP_DEPLOYMENT_LOG_RECORD_CRON="0 * * * *"
CLEANUP_DEPLOYMENT_LOG_RECORD_TIMEOUT=10m
CLEANUP_DEPLOYMENT_TARGET_LOG_RECORD_CRON="0 * * * *"
CLEANUP_DEPLOYMENT_TARGET_LOG_RECORD_TIMEOUT=10m
CLEANUP_OIDC_STATE_CRON="0 * * * *"
CLEANUP_OIDC_STATE_CRON_TIMEOUT=10m
CLEANUP_ARTIFACT_BLOB_CRON="0 * * * *"
CLEANUP_ARTIFACT_BLOB_TIMEOUT=10m
CLEANUP_ARTIFACT_BLOB_MIN_AGE=24h
CLEANUP_ORGANIZATION_CRON="0 0 * * *"
CLEANUP_ORGANIZATION_TIMEOUT=10m
CLEANUP_ORGANIZATION_MIN_AGE=720h

# Optional OIDC, tracing, Sentry, PostHog, Stripe, and license settings can be
# copied from deploy/docker/.env when needed.
