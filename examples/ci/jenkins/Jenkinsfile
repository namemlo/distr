pipeline {
  agent any

  environment {
    RELEASE_NUMBER = "${env.BUILD_NUMBER}"
    CI_RUN_ID = "${env.JOB_NAME}-${env.BUILD_NUMBER}"
    CI_RUN_URL = "${env.BUILD_URL}"
    IMAGE_DIGEST = "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
  }

  stages {
    stage('Build and test') {
      steps {
        sh 'echo "Run project build and tests here"'
      }
    }

    stage('Create release request') {
      steps {
        sh '''
          cat > release-bundle.json <<JSON
          {
            "applicationId": "$DISTR_APPLICATION_ID",
            "channelId": "$DISTR_CHANNEL_ID",
            "releaseNumber": "$RELEASE_NUMBER",
            "releaseNotes": "Automated release from Jenkins",
            "sourceRevision": "$GIT_COMMIT",
            "sourceMetadata": {
              "repository": "$GIT_URL",
              "branch": "$BRANCH_NAME",
              "tag": "",
              "ciProvider": "jenkins",
              "ciRunId": "$CI_RUN_ID",
              "ciRunUrl": "$CI_RUN_URL"
            },
            "components": [
              {
                "key": "api-image",
                "name": "API image",
                "type": "oci_image",
                "version": "$RELEASE_NUMBER",
                "packageRef": "registry.example.invalid/org/api",
                "digest": "$IMAGE_DIGEST"
              }
            ]
          }
          JSON
        '''
      }
    }

    stage('Create, validate, publish') {
      steps {
        sh '''
          create_output="$(
            distr release create \
              --file release-bundle.json \
              --idempotency-key "$CI_RUN_ID" \
              --output json
          )"
          release_bundle_id="$(printf '%s' "$create_output" | jq -r '.id')"
          distr release validate "$release_bundle_id"
          distr release publish "$release_bundle_id"
        '''
      }
    }
  }
}

