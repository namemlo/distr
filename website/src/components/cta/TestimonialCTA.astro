---
import {Image} from 'astro:assets';
import {Icon} from 'astro-icon/components';
import {getCollection, getEntry} from 'astro:content';
import DemoButton from '~/components/buttons/DemoButton.astro';
import SignupButton from '~/components/buttons/SignupButton.astro';

interface Props {
  name?: string;
}

const {name} = Astro.props;

let customer = name ? await getEntry('customers', name) : undefined;
if (!customer) {
  const featured = (
    await getCollection('customers', c => c.data.featured)
  ).sort((a, b) => a.id.localeCompare(b.id));
  customer = featured[0];
}

if (!customer) {
  throw new Error(
    `TestimonialCTA could not resolve a customer (name=${name ?? 'undefined'})`,
  );
}

const {company, person, quote, outcome, caseStudy} = customer.data;
const caseStudyUrl = caseStudy ? `/case-studies/${customer.id}/` : undefined;
---

<aside class="my-10 not-prose">
  <div
    class="max-w-2xl mx-auto bg-gradient-to-br from-accent-400 to-accent-600 dark:from-accent-600 dark:to-accent-950 rounded-xl p-6 md:p-8 shadow-[0_20px_60px_rgba(0,0,0,0.15)]"
    style="color: white;">
    <h2
      class="text-xl md:text-2xl font-bold text-center mb-5"
      style="color: white;">
      How vendors win with offering self-hosted
    </h2>
    <figure class="mx-auto text-center">
      <div class="flex items-center justify-center gap-2 mb-3">
        <Icon name="lucide:quote" class="h-6 shrink-0 text-white/70" />
        {
          outcome && (
            <p class="text-sm font-semibold uppercase tracking-wide text-accent-700 dark:text-accent-200">
              {outcome}
            </p>
          )
        }
      </div>
      <blockquote>
        <p
          class="text-sm md:text-base font-medium italic"
          style="color: white;">
          "{quote}"{' '}
          {
            caseStudyUrl && (
              <a
                href={caseStudyUrl}
                class="text-xs lowercase underline hover:no-underline whitespace-nowrap"
                style="color: white;">
                ...read more
              </a>
            )
          }
        </p>
      </blockquote>
      <figcaption class="flex items-center justify-center mt-6 space-x-3">
        <Image
          src={person.image}
          alt={person.name}
          class="w-6 h-6 rounded-full object-cover"
          width={48}
          height={48}
        />
        <div class="flex items-center divide-x-2 divide-white/30">
          <div class="pr-3 font-medium" style="color: white;">
            {person.name}
          </div>
          <div class="pl-3 text-sm font-light text-white/80">
            {person.role}, {company}
          </div>
        </div>
      </figcaption>
    </figure>
    <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
      <DemoButton class="w-full sm:w-auto" />
      <SignupButton class="w-full sm:w-auto" />
    </div>
  </div>
</aside>
