---
import DemoButton from '~/components/buttons/DemoButton.astro';
import SignupButton from '~/components/buttons/SignupButton.astro';

interface Props {
  bgClass?: string;
}

const {bgClass = 'bg-gray-50 dark:bg-gray-800'} = Astro.props;
---

<section class:list={['py-8 md:py-16 lg:py-24', bgClass]}>
  <div class="container mx-auto px-4 max-w-5xl">
    <div
      class="bg-gradient-to-br from-accent-400 to-accent-600 dark:from-accent-600 dark:to-accent-950 rounded-2xl p-8 md:p-12 lg:p-16 shadow-[0_20px_60px_rgba(0,0,0,0.15)] text-center"
      style="color: white;">
      <h2
        class="text-2xl md:text-3xl font-bold mb-4 md:mb-6"
        style="color: white;">
        Turn self-hosted into a repeatable sales motion
      </h2>
      <p
        class="text-base md:text-lg mb-6 md:mb-8 opacity-90 leading-relaxed max-w-3xl mx-auto"
        style="color: white;">
        From your first on-prem POC to dozens of enterprise customers, the Distr
        platform gives you the tooling to deploy, update and manage self-managed
        customers, backed by a team that supports you hands-on with the
        deployment knowledge and implementation help.
      </p>
      <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <DemoButton class="w-full md:w-auto" />
        <SignupButton class="w-full md:w-auto" />
      </div>
    </div>
  </div>
</section>
